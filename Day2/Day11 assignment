1. ImageField
    1-1 ImageField 특징과 사용법: 이미지를 업로드하고 저장하는 필드, pillow 라이브러리가 필요
        from django.db import models

        class Todo(models.Model):
            completed_image = models.ImageField(
                upload_to = 'competed_image/', # 저장경로
                null=True, # DB에 NULL 허용
                blank=True, # 폼에서 빈값 허용
        )
        thumbnail = models.ImageField(
            upload_to = 'thumbnails/',
            null=True,
            blank=True,
            default = 'thumbnails/default.png' # 기본값
        )

