import secrets as token_generator

import requests
from django.conf import settings
from django.contrib.auth import login as django_login
from django.shortcuts import redirect
from django.urls import reverse

from .models import User


def naver_login(request):
    state = token_generator.token_hex(16)
    request.session['naver_state'] = state

    callback_url = request.build_absolute_uri(reverse('naver_callback'))  # 외부에 전달하는 URL

    naver_auth_url = (
        f"https://nid.naver.com/oauth2.0/authorize"
        f"?client_id={settings.NAVER_CLIENT_ID}"
        f"&redirect_uri={callback_url}"
        f"&response_type=code"
        f"&state={state}"
    )
    return redirect(naver_auth_url)


def naver_callback(request):
    code = request.GET.get('code')
    state = request.GET.get('state')

    # state 검증
    if state != request.session.get('naver_state'):
        return redirect('login')

    callback_url = request.build_absolute_uri(reverse('naver_callback'))  # 외부에 전달하는 URL

    # access_token 요청
    token_response = requests.post(
        'https://nid.naver.com/oauth2.0/token',
        data={
            'grant_type': 'authorization_code',
            'client_id': settings.NAVER_CLIENT_ID,
            'client_secret': settings.NAVER_CLIENT_SECRET,
            'code': code,
            'state': state,
            'redirect_uri': callback_url,
        }
    )
    access_token = token_response.json().get('access_token')

    # 유저 정보 요청
    user_info_response = requests.get(
        'https://openapi.naver.com/v1/nid/me',
        headers={'Authorization': f'Bearer {access_token}'}
    )
    user_info = user_info_response.json().get('response')

    email = user_info.get('email')
    name = user_info.get('name')

    # 유저 조회 또는 생성
    user, created = User.objects.get_or_create(
        email=email,
        defaults={'name': name, 'is_active': True}
    )

    # 로그인 처리
    django_login(request, user, backend='django.contrib.auth.backends.ModelBackend')
    return redirect('cbv_todo_list')  # 내부 이동